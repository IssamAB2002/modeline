modeline.online {
    encode gzip

    # Django API
    @api path /api/*
    handle @api {
        reverse_proxy backend:8000
    }

    @admin path /admin/*
    handle @admin {
        reverse_proxy backend:8000
    }

    # Product pages → Django SSR (OG meta tags + embedded JSON hydration)
    @product path /product/*
    handle @product {
        reverse_proxy backend:8000
    }

    # Django-collected static files (admin, DRF)
    @static path /static/*
    handle @static {
        root * /srv/static
        uri strip_prefix /static
        file_server
    }

    # Uploaded media files
    @media path /media/*
    handle @media {
        root * /srv/media
        uri strip_prefix /media
        header Cache-Control "public, max-age=31536000, immutable"
        file_server
    }

    # Static frontend — all remaining routes served as an MPA
    handle {
        root * /srv/static-frontend
        try_files {path} {path}.html /index.html
        file_server
    }
}

www.modeline.online {
    redir https://modeline.online{uri} permanent
}
